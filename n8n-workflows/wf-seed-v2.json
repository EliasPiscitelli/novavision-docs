    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "seed-loop",
      "name": "Loop Items",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [
        440,
        0
      ]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst phone = (item.phone || '').replace(/[^0-9+]/g, '');\nconst email = (item.email || '').trim().toLowerCase();\n\nconst validPhone = /^\\+?[1-9]\\d{7,14}$/.test(phone);\nconst validEmail = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\n\nconst firstName = (item.name || 'hola').trim().split(' ')[0] || 'hola';\nconst senderName = $env.OUTREACH_SENDER_NAME || 'equipo NovaVision';\nconst businessName = (item.name || item.category || 'tu negocio').trim();\nconst sourceChannel = (item.source || 'base comercial').toString();\nconst currentSalesChannel = (item.last_channel || 'WhatsApp').toString();\nconst ctaLink = item.builder_url || item.web || (item.store_slug ? `https://${item.store_slug}.novavision.app` : '') || $env.OUTREACH_CTA_LINK || 'https://admin.novavision.app/onboarding/start';\n\nreturn [{\n  json: {\n    ...item,\n    phone_clean: validPhone ? phone : null,\n    email_clean: validEmail ? email : null,\n    has_valid_phone: validPhone,\n    has_valid_email: validEmail,\n    first_name: firstName,\n    sender_name: senderName,\n    business_name: businessName,\n    source_channel: sourceChannel,\n    current_sales_channel: currentSalesChannel,\n    cta_link: ctaLink\n  }\n}];"
      },
      "id": "seed-validate",
      "name": "Validate Contact",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        660,
        0
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": ""
          },
          "conditions": [
            {
              "id": "has-phone",
              "leftValue": "={{$json.has_valid_phone}}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "equals"
              }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "seed-has-phone",
      "name": "Has Valid Phone?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        880,
        0

{
  "name": "WF-SEED-V2 — Seed Diario",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 10,
              "triggerAtMinute": 0
            }
          ]
        }
      },
      "id": "seed-trigger",
      "name": "Cron Seed Diario",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_leads",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "select", "value": "id,name,email,phone,source,category,last_channel,web,builder_url,store_slug" },
            { "name": "status", "value": "eq.NEW" },
            { "name": "order", "value": "created_at.asc" },
            { "name": "limit", "value": "50" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=representation" }
          ]
        },
        "options": {}
      },
      "id": "seed-fetch",
      "name": "Fetch NEW Leads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0],
      "onError": "stopWorkflow"
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "seed-loop",
      "name": "Loop Items",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst phone = (item.phone || '').replace(/[^0-9+]/g, '');\nconst email = (item.email || '').trim().toLowerCase();\n\nconst validPhone = /^\\+?[1-9]\\d{7,14}$/.test(phone);\nconst validEmail = /^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$/.test(email);\n\nconst firstName = (item.name || 'hola').trim().split(' ')[0] || 'hola';\nconst senderName = $env.OUTREACH_SENDER_NAME || 'equipo NovaVision';\nconst businessName = (item.name || item.category || 'tu negocio').trim();\nconst sourceChannel = (item.source || 'base comercial').toString();\nconst currentSalesChannel = (item.last_channel || 'WhatsApp').toString();\nconst ctaLink = item.builder_url || item.web || (item.store_slug ? `https://${item.store_slug}.novavision.app` : '') || $env.OUTREACH_CTA_LINK || 'https://admin.novavision.app/onboarding/start';\n\nreturn [{\n  json: {\n    ...item,\n    phone_clean: validPhone ? phone : null,\n    email_clean: validEmail ? email : null,\n    has_valid_phone: validPhone,\n    has_valid_email: validEmail,\n    first_name: firstName,\n    sender_name: senderName,\n    business_name: businessName,\n    source_channel: sourceChannel,\n    current_sales_channel: currentSalesChannel,\n    cta_link: ctaLink\n  }\n}];"
      },
      "id": "seed-validate",
      "name": "Validate Contact",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "" },
          "conditions": [
            {
              "id": "has-phone",
              "leftValue": "={{$json.has_valid_phone}}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "seed-has-phone",
      "name": "Has Valid Phone?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [880, 0]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v22.0/{{$env.WHATSAPP_PHONE_NUMBER_ID}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{$env.WHATSAPP_TOKEN}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json.phone_clean}}\",\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"novavision_primer_contacto_qr_v1\",\n    \"language\": { \"code\": \"es_AR\" },\n    \"components\": [\n      {\n        \"type\": \"body\",\n        \"parameters\": [\n          { \"type\": \"text\", \"text\": \"{{$json.first_name}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.sender_name}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.business_name}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.source_channel}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.current_sales_channel}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.cta_link}}\" }\n        ]\n      }\n    ]\n  }\n}",
        "options": {}
      },
      "id": "seed-send-wa",
      "name": "Send WA Seed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, -100],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_leads?id=eq.{{$json.id}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"CONTACTED\",\n  \"last_channel\": \"WHATSAPP\",\n  \"last_contacted_at\": \"{{$now.toISO()}}\",\n  \"attempt_count\": 1,\n  \"next_followup_at\": \"{{$now.plus(3, 'days').toISO()}}\",\n  \"updated_at\": \"{{$now.toISO()}}\"\n}",
        "options": {}
      },
      "id": "seed-update-wa-ok",
      "name": "Update Lead WA OK",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, -200],
      "onError": "stopWorkflow"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_logs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"lead_id\": {{$json.id}},\n  \"channel\": \"WHATSAPP\",\n  \"action\": \"SEED_SENT\",\n  \"direction\": \"OUTBOUND\",\n  \"attempt\": 1,\n  \"wamid\": \"{{$json.messages ? $json.messages[0].id : null}}\",\n  \"message_text\": \"[TEMPLATE] novavision_primer_contacto_qr_v1\",\n  \"processing_status\": \"processed\"\n}",
        "options": {}
      },
      "id": "seed-log-wa-ok",
      "name": "Log WA Success",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, -200],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_logs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"lead_id\": {{$json.id}},\n  \"channel\": \"WHATSAPP\",\n  \"action\": \"SEED_FAILED\",\n  \"direction\": \"OUTBOUND\",\n  \"attempt\": 1,\n  \"error_message\": \"WA send failed\",\n  \"processing_status\": \"error\"\n}",
        "options": {}
      },
      "id": "seed-log-wa-fail",
      "name": "Log WA Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 0],
      "continueOnFail": true
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true, "leftValue": "" },
          "conditions": [
            {
              "id": "has-email",
              "leftValue": "={{$json.has_valid_email}}",
              "rightValue": true,

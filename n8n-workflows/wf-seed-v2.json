    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v22.0/{{$env.WHATSAPP_PHONE_NUMBER_ID}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.WHATSAPP_TOKEN}}"
            },
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json.phone_clean}}\",\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"novavision_primer_contacto_qr_v1\",\n    \"language\": { \"code\": \"es_AR\" },\n    \"components\": [\n      {\n        \"type\": \"body\",\n        \"parameters\": [\n          { \"type\": \"text\", \"text\": \"{{$json.first_name}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.sender_name}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.business_name}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.source_channel}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.current_sales_channel}}\" },\n          { \"type\": \"text\", \"text\": \"{{$json.cta_link}}\" }\n        ]\n      }\n    ]\n  }\n}",
        "options": {}
      },
      "id": "seed-send-wa",
      "name": "Send WA Seed",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1100,
        -100
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "operation": "executeQuery",
        "query": "UPDATE outreach_leads\nSET status = 'CONTACTED',\n    last_channel = 'WHATSAPP',\n    last_contacted_at = NOW(),\n    attempt_count = 1,\n    next_followup_at = NOW() + INTERVAL '3 days',\n    updated_at = NOW()\nWHERE id = '{{ $node[\"Validate Contact\"].json.id }}'\nRETURNING id"
      },
      "id": "seed-update-wa-ok",
      "name": "Update Lead WA OK",
      "type": "n8n-nodes-base.postgres",
      "typeVersion": 2.5,

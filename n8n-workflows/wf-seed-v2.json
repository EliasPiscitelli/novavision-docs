      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [880, 200]
    },
    {
      "parameters": {
        "fromEmail": "hola@novavision.com.ar",
        "toEmail": "={{$json.email_clean}}",
        "subject": "Tu tienda online en minutos — NovaVision",
        "emailType": "html",
        "html": "<div style=\"font-family:Arial,sans-serif;max-width:600px;margin:0 auto;padding:20px;\">\n<h2 style=\"color:#6C3CE1;\">¡Hola {{$json.name || 'emprendedor/a'}}! 👋</h2>\n<p>Soy del equipo de <strong>NovaVision</strong>. Te escribo porque vimos que tenés un emprendimiento y queremos ayudarte a vender online.</p>\n<p>Con NovaVision podés crear tu tienda online en <strong>menos de 15 minutos</strong>, sin necesidad de saber programar. Incluye:</p>\n<ul>\n<li>✅ Catálogo de productos con fotos</li>\n<li>✅ Carrito y pagos con Mercado Pago</li>\n<li>✅ Panel de administración simple</li>\n<li>✅ Diseño profesional optimizado para celular</li>\n</ul>\n<p style=\"text-align:center;margin:30px 0;\">\n<a href=\"https://novavision.com.ar/builder\" style=\"background:#6C3CE1;color:white;padding:14px 28px;text-decoration:none;border-radius:8px;font-weight:bold;display:inline-block;\">Crear mi tienda gratis →</a>\n</p>\n<p style=\"color:#666;font-size:13px;\">Si no te interesa, no te preocupes — no te vamos a molestar más. Podés responder este email con cualquier consulta.</p>\n</div>",
        "options": {}
      },
      "id": "seed-send-email",
      "name": "Send Email Seed",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [1100, 200],
      "credentials": {
        "gmailOAuth2": {
          "id": "yWIgAG6zWIonR54e",

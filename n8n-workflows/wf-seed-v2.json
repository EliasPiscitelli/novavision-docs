    {
      "parameters": {
        "operation": "executeQuery",
        "query": "SELECT id, name, email, phone, source, category, last_channel, web, builder_url, store_slug\nFROM outreach_leads\nWHERE status = 'NEW'\nORDER BY created_at ASC\nLIMIT 50"
      },

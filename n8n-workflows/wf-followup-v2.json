{
  "name": "WF-FU-V2 — Follow-ups",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            { "triggerAtHour": 11, "triggerAtMinute": 0 },
            { "triggerAtHour": 17, "triggerAtMinute": 0 }
          ]
        }
      },
      "id": "fu-trigger",
      "name": "Cron Follow-ups",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.2,
      "position": [0, 0]
    },
    {
      "parameters": {
        "method": "GET",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_leads",
        "sendQuery": true,
        "queryParameters": {
          "parameters": [
            { "name": "select", "value": "id,name,email,phone,company,status,attempt_count,last_channel,conversation_stage,source" },
            { "name": "status", "value": "eq.CONTACTED" },
            { "name": "next_followup_at", "value": "=lte.{{$now.toISO()}}" },
            { "name": "order", "value": "next_followup_at.asc" },
            { "name": "limit", "value": "100" }
          ]
        },
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "options": {}
      },
      "id": "fu-fetch",
      "name": "Fetch FU Leads",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0],
      "onError": "stopWorkflow"
    },
    {
      "parameters": {
        "batchSize": 1,
        "options": {}
      },
      "id": "fu-loop",
      "name": "Loop Items",
      "type": "n8n-nodes-base.splitInBatches",
      "typeVersion": 3,
      "position": [440, 0]
    },
    {
      "parameters": {
        "jsCode": "const item = $input.first().json;\nconst attemptCount = item.attempt_count || 0;\nconst fuNumber = attemptCount + 1;\nconst DELAYS = [3, 5, 7];\nconst maxAttempts = 4;\nconst isMaxReached = fuNumber >= maxAttempts;\nconst nextDelay = DELAYS[Math.min(fuNumber - 2, DELAYS.length - 1)] || 7;\nconst templateNum = Math.min(fuNumber - 1, 3);\n\nreturn [{\n  json: {\n    ...item,\n    fu_number: fuNumber,\n    is_max_reached: isMaxReached,\n    next_delay_days: nextDelay,\n    template_name: `novavision_followup${templateNum}`\n  }\n}];"
      },
      "id": "fu-compute",
      "name": "Compute FU Number",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [660, 0]
    },
    {
      "parameters": {
        "conditions": {
          "options": { "caseSensitive": true },
          "conditions": [
            {
              "id": "is-max",
              "leftValue": "={{$json.is_max_reached}}",
              "rightValue": true,
              "operator": { "type": "boolean", "operation": "equals" }
            }
          ],
          "combinator": "and"
        }
      },
      "id": "fu-is-max",
      "name": "Max Reached?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [880, 0]
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_leads?id=eq.{{$json.id}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"status\": \"COLD\",\n  \"next_followup_at\": null,\n  \"lost_reason\": \"max_followups_exhausted\",\n  \"updated_at\": \"{{$now.toISO()}}\"\n}",
        "options": {}
      },
      "id": "fu-mark-cold",
      "name": "Mark COLD",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, -200],
      "onError": "stopWorkflow"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_logs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"lead_id\": {{$json.id}},\n  \"channel\": \"SYSTEM\",\n  \"action\": \"MARKED_COLD\",\n  \"direction\": \"OUTBOUND\",\n  \"attempt\": {{$json.fu_number}},\n  \"message_text\": \"Max follow-ups reached, marked COLD\",\n  \"processing_status\": \"processed\"\n}",
        "options": {}
      },
      "id": "fu-log-cold",
      "name": "Log Marked COLD",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, -200],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v22.0/{{$env.WHATSAPP_PHONE_NUMBER_ID}}/messages",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "Authorization", "value": "=Bearer {{$env.WHATSAPP_TOKEN}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$json.phone}}\",\n  \"type\": \"template\",\n  \"template\": {\n    \"name\": \"{{$json.template_name}}\",\n    \"language\": { \"code\": \"es\" },\n    \"components\": [\n      {\n        \"type\": \"body\",\n        \"parameters\": [\n          { \"type\": \"text\", \"text\": \"{{$json.name || 'emprendedor/a'}}\" }\n        ]\n      }\n    ]\n  }\n}",
        "options": {}
      },
      "id": "fu-send-wa",
      "name": "Send WA Follow-up",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1100, 100],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "method": "PATCH",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_leads?id=eq.{{$json.id}}",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" },
            { "name": "Prefer", "value": "return=minimal" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"attempt_count\": {{$json.fu_number}},\n  \"last_channel\": \"WHATSAPP\",\n  \"last_contacted_at\": \"{{$now.toISO()}}\",\n  \"next_followup_at\": \"{{$now.plus($json.next_delay_days, 'days').toISO()}}\",\n  \"updated_at\": \"{{$now.toISO()}}\"\n}",
        "options": {}
      },
      "id": "fu-update-ok",
      "name": "Update Lead FU OK",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 50],
      "onError": "stopWorkflow"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_logs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"lead_id\": {{$json.id}},\n  \"channel\": \"WHATSAPP\",\n  \"action\": \"FU_SENT\",\n  \"direction\": \"OUTBOUND\",\n  \"attempt\": {{$json.fu_number}},\n  \"message_text\": \"[TEMPLATE] {{$json.template_name}}\",\n  \"processing_status\": \"processed\"\n}",
        "options": {}
      },
      "id": "fu-log-ok",
      "name": "Log FU Success",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1540, 50],
      "continueOnFail": true
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.SUPABASE_URL}}/rest/v1/outreach_logs",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            { "name": "apikey", "value": "={{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Authorization", "value": "=Bearer {{$env.SUPABASE_SERVICE_ROLE}}" },
            { "name": "Content-Type", "value": "application/json" }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"lead_id\": {{$json.id}},\n  \"channel\": \"WHATSAPP\",\n  \"action\": \"FU_FAILED\",\n  \"direction\": \"OUTBOUND\",\n  \"attempt\": {{$json.fu_number}},\n  \"error_message\": \"WA follow-up send failed\",\n  \"processing_status\": \"error\"\n}",
        "options": {}
      },
      "id": "fu-log-fail",
      "name": "Log FU Failure",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [1320, 250],
      "continueOnFail": true
    }
  ],
  "connections": {
    "Cron Follow-ups": {
      "main": [[{ "node": "Fetch FU Leads", "type": "main", "index": 0 }]]
    },
    "Fetch FU Leads": {
      "main": [[{ "node": "Loop Items", "type": "main", "index": 0 }]]
    },
    "Loop Items": {
      "main": [
        [{ "node": "Compute FU Number", "type": "main", "index": 0 }],
        []
      ]
    },
    "Compute FU Number": {
      "main": [[{ "node": "Max Reached?", "type": "main", "index": 0 }]]
    },
    "Max Reached?": {
      "main": [
        [{ "node": "Mark COLD", "type": "main", "index": 0 }],
        [{ "node": "Send WA Follow-up", "type": "main", "index": 0 }]
      ]
    },
    "Mark COLD": {
      "main": [[{ "node": "Log Marked COLD", "type": "main", "index": 0 }]]
    },
    "Log Marked COLD": {
      "main": [[{ "node": "Loop Items", "type": "main", "index": 0 }]]
    },
    "Send WA Follow-up": {
      "main": [
        [{ "node": "Update Lead FU OK", "type": "main", "index": 0 }],
        [{ "node": "Log FU Failure", "type": "main", "index": 0 }]
      ]
    },
    "Update Lead FU OK": {
      "main": [[{ "node": "Log FU Success", "type": "main", "index": 0 }]]
    },
    "Log FU Success": {
      "main": [[{ "node": "Loop Items", "type": "main", "index": 0 }]]
    },
    "Log FU Failure": {
      "main": [[{ "node": "Loop Items", "type": "main", "index": 0 }]]
    }
  },
  "pinData": {},
  "settings": {
    "executionOrder": "v1",
    "saveManualExecutions": true,
    "callerPolicy": "workflowsFromSameOwner"
  },
  "staticData": null,
  "tags": [{ "name": "outreach-v2" }, { "name": "followup" }],
  "triggerCount": 1,
  "updatedAt": "2025-07-23T00:00:00.000Z",
  "versionId": "fu-v2-001"
}

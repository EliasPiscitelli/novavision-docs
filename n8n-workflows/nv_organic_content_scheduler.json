              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Has Post": {
        "main": [
          [
            {
              "node": "Prepare Publish Payload",
              "type": "main",
              "index": 0
            }
          ],
          [
            {
              "node": "No Pending Posts",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Prepare Publish Payload": {
        "main": [
          [
            {
              "node": "Platform is Instagram",
              "type": "main",

            }
          ]
        ]
      },
      "Platform is Instagram": {
        "main": [
          [
            {
              "node": "IG Create Container",
              "type": "main",
              "index": 0
            }
          ],
          [
            {
              "node": "Publish to Facebook",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "IG Create Container": {
        "main": [

          ]
        ]
      },
      "IG Publish": {
        "main": [
          [
            {
              "node": "Update Supabase Status",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Publish to Facebook": {
        "main": [
          [
            {
              "node": "Update Supabase Status",
              "type": "main",
              "index": 0
            }
          ]
        ]
      },
      "Update Supabase Status": {
        "main": [
          [
            {
              "node": "WhatsApp Notify",
              "type": "main",
              "index": 0
            }
          ]
        ]
      }
    },
    "active": false,
    "settings": {
      "executionOrder": "v1",
      "timezone": "America/Argentina/Buenos_Aires"
    },

          "jsonBody": "={\n  \"messaging_product\": \"whatsapp\",\n  \"to\": \"{{$env.FOUNDER_PHONE}}\",\n  \"type\": \"text\",\n  \"text\": {\n    \"preview_url\": false,\n    \"body\": {{ JSON.stringify($('OpenAI Strategic Report').first().json.choices[0].message.content) }}\n  }\n}",
          "options": {}
        },
